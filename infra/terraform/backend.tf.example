# Remote state (recommended for production)
#
# 1. Create an S3 bucket and DynamoDB table for locking:
#    aws s3 mb s3://YOUR-ACCOUNT-priorauth-terraform-state --region us-east-1
#    aws dynamodb create-table \
#      --table-name priorauth-terraform-lock \
#      --attribute-definitions AttributeName=LockID,AttributeType=S \
#      --key-schema AttributeName=LockID,KeyType=HASH \
#      --billing-mode PAY_PER_REQUEST \
#      --region us-east-1
#
# 2. Copy this file to backend.tf and uncomment the backend block in versions.tf

terraform {
  backend "s3" {
    bucket         = "YOUR-ACCOUNT-priorauth-terraform-state"
    key            = "priorauth/terraform.tfstate"
    region         = "us-east-1"
    encrypt        = true
    dynamodb_table = "priorauth-terraform-lock"
  }
}
